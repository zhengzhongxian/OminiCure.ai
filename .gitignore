# ==============================================================================
# OmniCure.ai - Comprehensive .gitignore
# Covers .NET, Docker, IDEs, OS files, and common development artifacts
# ==============================================================================

## ========================
## .NET / ASP.NET Core
## ========================

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core / ASP.NET Core
*.nuspec
*.nupkg
*.snk
*.DotSettings.user
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.pcfg

# Visual Studio files
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
*.pidb
*.booproj
*.sln.ide/

# Mono auto generated
auto_generated/

# Build results
*.cache
*.ilexe
*.lastcodeanalysissucceeded

# MSTest test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# JetBrains Rider
*.sln.iml
.idea/

## ========================
## Java / Maven / Spring
## ========================

# Maven build output
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# STS (Spring Tool Suite)
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# IntelliJ IDEA (additional Java-specific)
*.iws
*.iml
*.ipr

# NetBeans
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/
!**/src/main/**/build/
!**/src/test/**/build/

