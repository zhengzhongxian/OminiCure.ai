# ==============================================================================
# OmniCure.ai - Environment Variables
# Copy this file to .env and update values for your environment
# ==============================================================================

# ==============================================================================
# Application Settings
# ==============================================================================
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:80
DOTNET_RUNNING_IN_CONTAINER=true

# ==============================================================================
# Kafka Configuration
# ==============================================================================
KAFKA_VERSION=7.5.1
KAFKA_UI_VERSION=v0.7.2
KAFKA_PORT=9092
KAFKA_CONTROLLER_PORT=9093
KAFKA_UI_PORT=9090
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_LOG_SEGMENT_BYTES=1073741824

# ==============================================================================
# Oracle Database Configuration
# ==============================================================================
ORACLE_VERSION=21.3.0.0
ORACLE_PORT=1521
ORACLE_EM_PORT=5500
ORACLE_PASSWORD=ChangeMe_In_Production_2024!
ORACLE_CHARACTERSET=AL32UTF8
ORACLE_EDITION=enterprise
ORACLE_MEMORY_LIMIT=4g
ORACLE_CPU_LIMIT=2.0

# Oracle Connection Strings
ORACLE_CONNECTION_STRING_BILLING=User Id=billing_db;Password=ChangeMe_In_Production_2024!;Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=oracle-db)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=FREEPDB1)));Max Pool Size=100;Min Pool Size=10;Connection Timeout=30;
ORACLE_CONNECTION_STRING_HISADMIN=User Id=hisadmin_db;Password=ChangeMe_In_Production_2024!;Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=oracle-db)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=FREEPDB1)));Max Pool Size=100;Min Pool Size=10;Connection Timeout=30;

# ==============================================================================
# Redis Configuration
# ==============================================================================
REDIS_VERSION=7.2.4-v6
REDIS_PORT=6379
REDIS_INSIGHT_PORT=8001
REDIS_PASSWORD=ChangeMe_In_Production_2024!
REDIS_MAXMEMORY=2gb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_CONNECTION_STRING=redis:6379,password=ChangeMe_In_Production_2024!,abortConnect=false,connectTimeout=5000,responseTimeout=5000

# ==============================================================================
# ELK Stack Configuration
# ==============================================================================
ELASTIC_VERSION=8.12.0
ELASTIC_PORT=9200
ELASTIC_TRANSPORT_PORT=9300
ELASTIC_PASSWORD=ChangeMe_In_Production_2024!
ELASTIC_JAVA_OPTS=-Xms512m -Xmx1g
KIBANA_PORT=5601
KIBANA_ELASTIC_USER=elastic
LOGSTASH_PORT=5044
LOGSTASH_API_PORT=9600
LOGSTASH_JAVA_OPTS=-Xms256m -Xmx512m

# ==============================================================================
# Billing Service Configuration
# ==============================================================================
BILLING_SERVICE_PORT=5001
BILLING_SERVICE_HEALTH_PORT=5002
BILLING_DB_CONNECTION_STRING=User Id=billing_db;Password=ChangeMe_In_Production_2024!;Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=oracle-db)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=FREEPDB1)));Max Pool Size=100;
BILLING_REDIS_CONNECTION_STRING=redis:6379,password=ChangeMe_In_Production_2024!,abortConnect=false

# ==============================================================================
# Laboratory Service Configuration
# ==============================================================================
LAB_SERVICE_PORT=5003
LAB_SERVICE_HEALTH_PORT=5004
LAB_MONGODB_CONNECTION_STRING=mongodb://mongo:27017/omnicure_lab?retryWrites=true&w=majority
LAB_REDIS_CONNECTION_STRING=redis:6379,password=ChangeMe_In_Production_2024!,abortConnect=false

# ==============================================================================
# HIS Admin Service Configuration
# ==============================================================================
HISADMIN_SERVICE_PORT=5005
HISADMIN_SERVICE_HEALTH_PORT=5006
HISADMIN_DB_CONNECTION_STRING=User Id=hisadmin_db;Password=ChangeMe_In_Production_2024!;Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=oracle-db)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=FREEPDB1)));Max Pool Size=100;
HISADMIN_REDIS_CONNECTION_STRING=redis:6379,password=ChangeMe_In_Production_2024!,abortConnect=false

# ==============================================================================
# Kong API Gateway Configuration
# ==============================================================================
KONG_ADMIN_PORT=8001
KONG_PROXY_PORT=8000
KONG_ADMIN_GUI_PORT=8002
KONG_PROXY_LISTEN_PORT=8000
KONG_DATABASE=off

# ==============================================================================
# Docker Registry (Optional - for private registries)
# ==============================================================================
DOCKER_REGISTRY=
DOCKER_REGISTRY_USERNAME=
DOCKER_REGISTRY_PASSWORD=

# ==============================================================================
# Logging
# ==============================================================================
SERILOG_MINIMUM_LEVEL=Information
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=ChangeMe_In_Production_2024!
